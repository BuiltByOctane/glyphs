{
  "name": "glyphs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "description": "A fast, keyboard-first clipboard manager for macOS, Windows, and Linux.",
  "license": "MIT",
  "homepage": "https://github.com/builtbyoctane/glyphs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/builtbyoctane/glyphs.git"
  },
  "bugs": {
    "url": "https://github.com/builtbyoctane/glyphs/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf dist src-tauri/target src-tauri/gen/schemas src-tauri/crash.log && find . -name '.DS_Store' -type f -not -path './node_modules/*' -delete",
    "clean:all": "pnpm clean && rm -rf node_modules"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.9",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.2.2",
    "uuid": "^13.0.0",
    "vite": "^5.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
